# Copy to .env for local development. Never commit the real .env file.
# In production these are injected by the secrets manager (e.g. AWS Secrets
# Manager / GCP Secret Manager / Vault), not read from a file.

# Used by the migration runner (Alembic) — should be a role that owns the
# schema objects (DDL rights), never the runtime application role.
MIGRATOR_DATABASE_URL=postgresql+psycopg://dreamers_migrator@localhost:5432/dreamers_media

# Used by the FastAPI app at runtime — a least-privilege role with no
# UPDATE/DELETE grants on ledger_transactions, ledger_entries, or audit_log.
APP_DATABASE_URL=postgresql+psycopg://app_rw@localhost:5432/dreamers_media

# Used by reporting/BI tooling and the future read-only-auditor role.
READONLY_DATABASE_URL=postgresql+psycopg://app_ro@localhost:5432/dreamers_media

# Auth0 tenant details (Phase 2). AUTH0_AUDIENCE is the API identifier
# configured in Auth0, not the client ID -- the API layer verifies bearer
# JWTs against this audience and against
# https://{AUTH0_DOMAIN}/.well-known/jwks.json, it does not perform the
# OAuth login flow itself (that's the client application's job).
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://dreamers-media-pacific-api
